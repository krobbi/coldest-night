# Laser Terminal
# Common cutscene for laser terminal in test.area_bx.west.

define state test:west_laser_state

player freeze
dialog show
say "DIALOG.TEST.LASER_TERMINAL.PROMPT"

menu option "DIALOG.TEST.LASER_TERMINAL.OPTION.REDIRECT" goto redirect
menu option "DIALOG.TEST.LASER_TERMINAL.OPTION.CANCEL" goto cancel
menu show

label redirect
	if state
		set state false
	else
		set state true
	end

	say "DIALOG.TEST.LASER_TERMINAL.REDIRECTED"
	goto cancel


label cancel
	dialog hide
	player unfreeze
	exit
